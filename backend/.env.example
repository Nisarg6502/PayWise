# Copy to .env and fill in real values. Never commit .env.

# --- App ---
DEBUG=true
FRONTEND_ORIGIN=http://localhost:3000

# --- PostgreSQL (matches docker-compose.yml defaults) ---
POSTGRES_USER=ccopt
POSTGRES_PASSWORD=ccopt_dev_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ccopt

# --- Qdrant Cloud (default) ---
# Get both from https://cloud.qdrant.io -> your cluster -> "API Keys"
QDRANT_URL=https://<your-cluster-id>.<region>.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=card_rules
# Local Docker alternative: QDRANT_URL=http://localhost:6333 (no API key)

# --- LLM ---
LLM_PROVIDER=ollama            # "ollama" (gpt-oss:120b, free) or "hf" (Qwen3)
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=
LLM_MODEL=gpt-oss:120b
# For LLM_PROVIDER=hf — Qwen3 via HF Inference Providers (small free monthly credits):
HF_TOKEN=
HF_LLM_MODEL=Qwen/Qwen3-32B

# --- Embeddings + reranker: Jina AI API (free key at https://jina.ai) ---
JINA_API_KEY=
EMBEDDING_PROVIDER=jina
RERANKER_PROVIDER=jina
# Set both providers to "local" to use sentence-transformers instead
# (downloads nomic-embed-text-v1.5 ~550MB and bge-reranker-v2-m3 ~2.3GB)

# --- Google OAuth 2.0 / JWT (Phase 2) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
